-# app/views/web/sales_ledger/imports/show.html.haml

.container.mx-auto.px-6.py-8
  -# Breadcrumb
  .text-sm.text-slate-500.mb-4
    %span Ventas
    %span.mx-1 ›
    = link_to "Ventas Importadas", web_sales_ledger_imports_path,
              class: "text-teal-600 hover:underline"
    %span.mx-1 ›
    %span.text-slate-900.font-medium= @import.source_filename

  %h1.text-2xl.font-bold.text-slate-900.mb-1 Detalle de importación
  %p.text-sm.text-slate-500.mb-6= @import.imported_at&.strftime("%d/%m/%Y a las %H:%M hs")

  -# Métricas del lote
  .grid.grid-cols-3.gap-4.mb-6
    .card.p-4.text-center
      %p.text-3xl.font-bold.text-slate-900= @import.created_entries_count
      %p.text-xs.text-slate-500.mt-1 Filas importadas
    .card.p-4.text-center
      %p.text-3xl.font-bold.text-slate-900= @import.created_products_count
      %p.text-xs.text-slate-500.mt-1 Productos creados
    .card.p-4.text-center
      %p.text-3xl.font-bold{ class: @import.failed_rows_count > 0 ? "text-red-600" : "text-slate-900" }
        = @import.failed_rows_count
      %p.text-xs.text-slate-500.mt-1 Filas con error

  -# Alerta de tickets con diferencia de totales
  - mismatch_count = @entries.count(&:ticket_amount_mismatch)
  - if mismatch_count > 0
    .bg-yellow-50.border.border-yellow-200.rounded-lg.px-4.py-3.mb-6.text-sm.text-yellow-800
      %strong #{mismatch_count} ticket(s) con diferencia entre total declarado y total calculado.
      Ver filas marcadas con
      %span.bg-yellow-200.text-yellow-800.text-xs.font-medium.px-2.py-0.5.rounded ∆ dif.
      en la tabla.

  -# Notas / errores del proceso
  - if @import.notes.present?
    .bg-yellow-50.border.border-yellow-200.rounded-lg.p-4.mb-6
      %p.text-xs.font-semibold.text-yellow-800.mb-2 Notas del proceso
      %pre.text-xs.text-yellow-700.whitespace-pre-wrap= @import.notes

  -# Tabla de entradas
  .card.overflow-hidden
    %table.w-full.text-sm
      %thead.bg-slate-50
        %tr
          %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Fecha
          %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Ticket
          %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide OEM
          %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Producto
          %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Cant.
          %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Precio
          %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Total línea
          %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Total ticket
          %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Vendedor
          %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Pago
      %tbody.divide-y.divide-slate-100
        - @entries.each do |entry|
          %tr.hover:bg-slate-50
            %td.px-4.py-3.text-slate-600= entry.sale_date.strftime("%d/%m/%Y")
            %td.px-4.py-3.font-mono.text-slate-700= entry.ticket_number
            %td.px-4.py-3.font-mono.text-xs.text-slate-500= entry.oem_code
            %td.px-4.py-3.text-slate-800= entry.product_name_snapshot
            %td.px-4.py-3.text-right.text-slate-700= entry.quantity
            %td.px-4.py-3.text-right.text-slate-600
              = number_to_currency(entry.unit_price, unit: "$", separator: ",", delimiter: ".")
            %td.px-4.py-3.text-right.font-medium.text-slate-900
              = number_to_currency(entry.total_amount, unit: "$", separator: ",", delimiter: ".")
            %td.px-4.py-3.text-right
              - if entry.ticket_total_amount.present?
                - if entry.ticket_amount_mismatch?
                  %span.inline-flex.items-center.gap-1
                    = number_to_currency(entry.ticket_total_amount, unit: "$", separator: ",", delimiter: ".")
                    %span.bg-yellow-200.text-yellow-800.text-xs.font-medium.px-1.5.py-0.5.rounded ∆ dif.
                - else
                  = number_to_currency(entry.ticket_total_amount, unit: "$", separator: ",", delimiter: ".")
              - else
                %span.text-slate-300 —
            %td.px-4.py-3.text-slate-700= entry.seller_name.presence || "—"
            %td.px-4.py-3
              - if entry.payment_method.present?
                %span.inline-block.text-xs.font-medium.px-2.py-0.5.rounded-full{ class: payment_method_badge_class(entry.payment_method) }
                  = entry.payment_method
              - else
                %span.text-slate-300 —

  .mt-4
