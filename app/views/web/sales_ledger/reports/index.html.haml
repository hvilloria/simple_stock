-# app/views/web/sales_ledger/reports/index.html.haml

.container.mx-auto.px-6.py-8

  -# Breadcrumb
  .text-sm.text-slate-500.mb-4
    %span Ventas
    %span.mx-1 ›
    %span.text-slate-900.font-medium Reportes

  -# Header
  .flex.items-center.justify-between.mb-6
    %h1.text-2xl.font-bold.text-slate-900 Reportes de Ventas

  -# Filtro de período
  .bg-white.border.border-slate-200.rounded-lg.p-4.mb-6
    = form_with url: web_sales_ledger_reports_path, method: :get,
                class: "flex items-center gap-4 flex-wrap" do |f|
      %label.text-sm.font-medium.text-slate-700 Desde
      = f.date_field :from, value: @from, class: "input-modern w-auto"

      %label.text-sm.font-medium.text-slate-700 Hasta
      = f.date_field :to, value: @to, class: "input-modern w-auto"

      = f.submit "Filtrar", class: "btn-primary"

      - if params[:from].present? || params[:to].present?
        = link_to "Limpiar", web_sales_ledger_reports_path,
                  class: "text-sm text-slate-500 hover:text-slate-700"

  -# KPI cards
  .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-4.gap-6.mb-8

    -# Revenue Total
    .bg-white.border.border-slate-200.rounded-lg.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-xs.font-medium.text-slate-500.uppercase.tracking-wide.mb-2 Revenue Total
          %h3.text-3xl.font-bold.text-slate-900
            = number_to_currency(@summary[:reported], unit: "$", separator: ",", delimiter: ".", precision: 0)
        .w-10.h-10.bg-slate-100.rounded-lg.flex.items-center.justify-center.text-xl
          💰
      %p.text-xs.text-slate-500 Período seleccionado

    -# Unidades Vendidas
    .bg-white.border.border-slate-200.rounded-lg.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-xs.font-medium.text-slate-500.uppercase.tracking-wide.mb-2 Unidades Vendidas
          %h3.text-3xl.font-bold.text-slate-900= number_with_delimiter(@summary[:units])
        .w-10.h-10.bg-slate-100.rounded-lg.flex.items-center.justify-center.text-xl
          📦
      %p.text-xs.text-slate-500 Sum de cantidades

    -# Tickets Únicos
    .bg-white.border.border-slate-200.rounded-lg.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-xs.font-medium.text-slate-500.uppercase.tracking-wide.mb-2 Tickets Únicos
          %h3.text-3xl.font-bold.text-slate-900= number_with_delimiter(@summary[:tickets])
        .w-10.h-10.bg-blue-100.rounded-lg.flex.items-center.justify-center.text-xl
          🧾
      %p.text-xs.text-slate-500 Transacciones distintas

    -# Productos Únicos
    .bg-white.border.border-slate-200.rounded-lg.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-xs.font-medium.text-slate-500.uppercase.tracking-wide.mb-2 Productos Únicos
          %h3.text-3xl.font-bold.text-slate-900= number_with_delimiter(@summary[:unique_products])
        .w-10.h-10.bg-slate-100.rounded-lg.flex.items-center.justify-center.text-xl
          🔩
      %p.text-xs.text-slate-500 Códigos OEM distintos

  -# Estado vacío
  - if @summary[:units] == 0
    .bg-white.border.border-slate-200.rounded-lg.p-16.text-center.mb-8
      .inline-flex.w-20.h-20.rounded-full.bg-slate-100.items-center.justify-center.text-4xl.mb-4
        📋
      %h3.text-xl.font-bold.text-slate-900.mb-2 Sin datos en este período
      %p.text-slate-500
        No hay ventas importadas entre
        %strong= @from.strftime("%d/%m/%Y")
        y
        %strong= @to.strftime("%d/%m/%Y")
      %p.text-sm.text-slate-400.mt-2
        = link_to "Importar un CSV", web_sales_ledger_imports_path, class: "text-teal-600 hover:underline"
        para agregar ventas al período.

  - else

    -# Tabla: Ventas por Día
    .mb-8
      .flex.items-center.justify-between.mb-3
        %h2.text-base.font-semibold.text-slate-900 Ventas por Día
      .bg-white.border.border-slate-200.rounded-lg.overflow-hidden
        %table.min-w-full.divide-y.divide-slate-200
          %thead.bg-slate-50
            %tr
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Fecha
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Revenue
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Reportado
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Medio de pago
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Unidades
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Tickets
          %tbody.divide-y.divide-slate-100
            - @sales_by_date.each do |row|
              %tr.hover:bg-slate-50.transition-colors
                %td.px-4.py-3.text-slate-700= row.sale_date.strftime("%d/%m/%Y")
                %td.px-4.py-3.text-right.font-medium.text-slate-900
                  = number_to_currency(row.revenue, unit: "$", separator: ",", delimiter: ".", precision: 0)
                %td.px-4.py-3.text-right.font-medium.text-slate-900
                  = number_to_currency(row.ticket_total_amount, unit: "$", separator: ",", delimiter: ".", precision: 0)
                %td.px-4.py-3.text-right
                  %span.inline-flex.items-center.px-2.5.py-1.rounded-md.text-xs.font-medium{class: payment_method_badge_class(row.payment_method)}
                    = payment_method_label(row.payment_method)
                %td.px-4.py-3.text-right.text-slate-700= number_with_delimiter(row.units)
                %td.px-4.py-3.text-right.text-slate-500= row.tickets

    -# Dos columnas: Top Productos + Últimas Ventas
    .grid.grid-cols-1.lg:grid-cols-2.gap-6

      -# Tabla: Top Productos
      .bg-white.border.border-slate-200.rounded-lg.overflow-hidden
        .px-4.py-3.border-b.border-slate-200
          %h2.text-base.font-semibold.text-slate-900 Top Productos
        %table.min-w-full.divide-y.divide-slate-200
          %thead.bg-slate-50
            %tr
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide OEM
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Nombre
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Unidades
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Revenue
          %tbody.divide-y.divide-slate-100
            - @top_products.each do |row|
              %tr.hover:bg-slate-50.transition-colors
                %td.px-4.py-3.font-mono.text-xs.text-slate-500= row.oem_code
                %td.px-4.py-3.text-slate-800.text-sm= row.product_name
                %td.px-4.py-3.text-right.font-medium.text-slate-900= number_with_delimiter(row.total_quantity)
                %td.px-4.py-3.text-right.text-slate-700
                  = number_to_currency(row.total_revenue, unit: "$", separator: ",", delimiter: ".", precision: 0)

      -# Tabla: Últimas Ventas
      .bg-white.border.border-slate-200.rounded-lg.overflow-hidden
        .px-4.py-3.border-b.border-slate-200
          %h2.text-base.font-semibold.text-slate-900 Últimas Ventas Importadas
        %table.min-w-full.divide-y.divide-slate-200
          %thead.bg-slate-50
            %tr
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Fecha
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Ticket
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide OEM
              %th.px-4.py-3.text-left.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Producto
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Cant.
              %th.px-4.py-3.text-right.text-xs.font-semibold.text-slate-500.uppercase.tracking-wide Total
          %tbody.divide-y.divide-slate-100
            - @recent_entries.each do |entry|
              %tr.hover:bg-slate-50.transition-colors
                %td.px-4.py-3.text-slate-600= entry.sale_date.strftime("%d/%m/%Y")
                %td.px-4.py-3.font-mono.text-slate-700= entry.ticket_number
                %td.px-4.py-3.font-mono.text-xs.text-slate-500= entry.oem_code
                %td.px-4.py-3.text-slate-800.text-sm= entry.product_name_snapshot
                %td.px-4.py-3.text-right.text-slate-700= entry.quantity
                %td.px-4.py-3.text-right.font-medium.text-slate-900
                  = number_to_currency(entry.total_amount, unit: "$", separator: ",", delimiter: ".", precision: 0)
