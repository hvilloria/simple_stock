- customer_type_options = [["Minorista", "retail"], ["Taller", "workshop"], ["Mecánico", "mechanic"], ["Tienda", "store"]]

= form_with model: [:web, @customer], local: true, class: "space-y-6", data: { controller: "customer-form" } do |f|

  -# Errors
  - if @customer.errors.any?
    .bg-red-50.border-l-4.border-red-500.p-4.rounded-lg.mb-6
      %h4.font-semibold.text-red-800.mb-2
        = pluralize(@customer.errors.count, "error")
        impidió guardar el cliente:
      %ul.list-disc.list-inside.text-sm.text-red-700
        - @customer.errors.full_messages.each do |message|
          %li= message

  -# Basic info card
  .bg-white.border.border-slate-200.rounded-lg.p-6
    %h3.text-lg.font-semibold.text-gray-900.mb-4 Información Básica

    .space-y-4
      -# Name
      %div
        = f.label :name, "Nombre del Cliente *", class: "block text-sm font-medium text-gray-700 mb-2"
        = f.text_field :name,
                      placeholder: "Ej: Juan Pérez",
                      class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all",
                      required: true

      -# Customer type
      %div
        = f.label :customer_type, "Tipo de Cliente", class: "block text-sm font-medium text-gray-700 mb-2"
        = f.select :customer_type,
                  customer_type_options,
                  {},
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all",
                  data: { action: "change->customer-form#customerTypeChanged" }

      -# Document
      %div
        = f.label :document, "Documento", class: "block text-sm font-medium text-gray-700 mb-2"
        = f.text_field :document,
                      placeholder: "DNI / CUIT",
                      class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all"

      -# Phone
      %div
        = f.label :phone, "Teléfono", class: "block text-sm font-medium text-gray-700 mb-2"
        = f.text_field :phone,
                      placeholder: "11-1234-5678",
                      class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all"

      -# Current account
      .bg-slate-50.border.border-slate-200.rounded-lg.p-4
        %label.flex.items-start.gap-3.cursor-pointer
          = f.check_box :has_credit_account,
                       class: "mt-1 h-4 w-4 text-slate-700 border-gray-300 rounded focus:ring-slate-500",
                       data: { customer_form_target: "creditAccountCheckbox" }
          %div
            %span.block.text-sm.font-semibold.text-slate-900 Habilitar Cuenta Corriente
            %span.block.text-xs.text-slate-600.mt-1
              Permite realizar ventas a crédito y registrar pagos posteriores.

  -# Buttons
  .flex.items-center.gap-4
    = f.submit submit_label, class: "px-6 py-3 bg-slate-700 hover:bg-slate-800 text-white font-semibold rounded-lg transition-colors"
    = link_to "Cancelar", cancel_path, class: "px-6 py-3 border border-slate-300 text-slate-700 font-semibold rounded-lg hover:bg-slate-50 transition-colors"
