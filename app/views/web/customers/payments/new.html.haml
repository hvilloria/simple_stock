- content_for :page_title, "Registrar Pago"

- payment_method_options = [["Efectivo", "cash"], ["Transferencia", "transfer"], ["Cheque", "check"], ["Tarjeta", "card"]]

.container.mx-auto.px-6.py-6.max-w-2xl

  -# Header
  .flex.items-center.gap-4.mb-6
    = link_to web_customer_path(@customer), class: "text-gray-600 hover:text-gray-900" do
      %span.text-xl ←
    %div
      %h1.text-3xl.font-bold.text-gray-900 Registrar Pago
      %p.text-sm.text-slate-600.mt-1= @customer.name

  -# Mensajes
  - if flash[:alert]
    .bg-red-50.border-l-4.border-red-500.p-4.rounded-lg.mb-6.flex.items-start.gap-3
      .w-10.h-10.rounded-xl.bg-red-500.flex.items-center.justify-center.text-white.flex-shrink-0
        ⚠️
      .flex-1
        %h4.font-semibold.text-red-800.mb-1 Error
        %p.text-sm.text-red-700= flash[:alert]

  = form_with url: web_customer_payments_path(@customer), model: @payment, local: true, class: "space-y-6" do |f|

    -# Errores de validación (modelo)
    - if @payment.errors.any?
      .bg-red-50.border-l-4.border-red-500.p-4.rounded-lg.mb-6
        %h4.font-semibold.text-red-800.mb-2
          = pluralize(@payment.errors.count, "error")
          impidió registrar el pago:
        %ul.list-disc.list-inside.text-sm.text-red-700
          - @payment.errors.full_messages.each do |message|
            %li= message

    -# Card Detalle del Pago
    .bg-white.border.border-slate-200.rounded-lg.p-6
      %h3.text-lg.font-semibold.text-gray-900.mb-4 Detalle del Pago

      .space-y-4
        -# Monto
        %div
          = f.label :amount, "Monto *", class: "block text-sm font-medium text-gray-700 mb-2"
          = f.number_field :amount,
                          step: "0.01",
                          min: "0.01",
                          placeholder: "0,00",
                          class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all",
                          required: true

        -# Método de pago
        %div
          = f.label :payment_method, "Método de Pago *", class: "block text-sm font-medium text-gray-700 mb-2"
          = f.select :payment_method,
                    payment_method_options,
                    {},
                    class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all"

        -# Fecha
        %div
          = f.label :payment_date, "Fecha de Pago *", class: "block text-sm font-medium text-gray-700 mb-2"
          = f.date_field :payment_date,
                        value: (@payment.payment_date || Date.today),
                        class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all",
                        required: true

        -# Notas
        %div
          = f.label :notes, "Notas", class: "block text-sm font-medium text-gray-700 mb-2"
          = f.text_area :notes,
                       rows: 3,
                       placeholder: "Referencia, detalles adicionales, etc.",
                       class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all"

    -# Botones
    .flex.items-center.gap-4
      = f.submit "Registrar Pago", class: "px-6 py-3 bg-slate-700 hover:bg-slate-800 text-white font-semibold rounded-lg transition-colors"
      = link_to "Cancelar", web_customer_path(@customer), class: "px-6 py-3 border border-slate-300 text-slate-700 font-semibold rounded-lg hover:bg-slate-50 transition-colors"
