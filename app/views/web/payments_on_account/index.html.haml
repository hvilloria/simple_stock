- content_for :page_title, "Pagos a cuenta"

.container.mx-auto.px-6.py-6
  .mb-4
    %h1.text-2xl.font-semibold.text-slate-900 Pagos a cuenta
    %p.text-sm.text-slate-500 Operaciones abiertas — pendientes de pago o entrega

  = form_with url: web_payments_on_account_index_path, method: :get, class: "mb-4 max-w-md" do |f|
    = f.text_field :q, value: params[:q], placeholder: "Buscar por nombre o teléfono…",
      class: "w-full px-4 py-2.5 border border-slate-300 rounded-xl text-sm bg-white"

  - if @operations.any?
    .bg-white.border.border-slate-200.rounded-2xl.overflow-hidden
      %table.w-full.text-sm
        %thead
          %tr.text-slate-500.text-left.bg-slate-50
            %th.px-4.py-2.5.font-medium Cliente
            %th.px-4.py-2.5.font-medium Teléfono
            %th.px-4.py-2.5.font-medium Talonario
            %th.px-4.py-2.5.font-medium.text-right Total
            %th.px-4.py-2.5.font-medium.text-right Pagado
            %th.px-4.py-2.5.font-medium.text-right Saldo
            %th.px-4.py-2.5.font-medium.text-center Entrega
            %th.px-4.py-2.5
        %tbody.divide-y.divide-slate-100
          - @operations.each do |op|
            - paid = op.total_amount - op.outstanding_balance
            %tr.hover:bg-slate-50
              %td.px-4.py-3.font-medium= op.contact_name
              %td.px-4.py-3.text-slate-600= op.contact_phone
              %td.px-4.py-3.text-slate-600= op.paper_number
              %td.px-4.py-3.text-right= number_to_currency(op.total_amount, unit: "$", separator: ",", delimiter: ".")
              %td.px-4.py-3.text-right.text-slate-600= number_to_currency(paid, unit: "$", separator: ",", delimiter: ".")
              %td.px-4.py-3.text-right.font-medium= number_to_currency(op.outstanding_balance, unit: "$", separator: ",", delimiter: ".")
              %td.px-4.py-3.text-center
                %span.inline-flex.items-center.px-2.py-0.5.rounded-full.bg-amber-100.text-amber-700.text-xs.font-medium
                  = "#{op.delivered_items_count}/#{op.order_items.size}"
              %td.px-4.py-3.text-right
                = link_to "Ver →", web_payments_on_account_path(op), class: "text-sm font-medium text-slate-900 hover:underline"
  - else
    .bg-white.border.border-slate-200.rounded-2xl.p-8.text-center.text-slate-500
      No hay operaciones abiertas.
