- content_for :page_title, "Pagos Pendientes"

.container.mx-auto.px-6.py-6

  -# Header
  .flex.items-center.justify-between.mb-6
    .flex-1
      %h1.text-3xl.font-bold.text-gray-900 💸 Pagos Pendientes
      %p.text-sm.text-gray-600.mt-1
        Facturas pendientes de pago agrupadas por proveedor

    .text-right
      %p.text-xs.text-gray-500 Última actualización
      %p.text-sm.font-medium.text-gray-700= Time.current.strftime("%d/%m/%Y %H:%M")

  -# Filtro de período
  .bg-white.border.border-slate-200.rounded-lg.p-4.mb-6
    = form_with url: pending_web_invoices_path, method: :get, class: "flex items-center gap-4" do |f|

      %label.text-sm.font-medium.text-gray-700 Mostrar:

      = select_tag :period, options_for_select([["Esta Semana (#{Date.current.beginning_of_week.strftime('%d/%m')} - #{Date.current.end_of_week.strftime('%d/%m')})", "this_week"], ["Próxima Semana", "next_week"], ["Este Mes (#{Date.current.strftime('%B')})", "this_month"], ["Próximo Mes", "next_month"], ["⚠️ Vencidas (atrasadas)", "overdue"]], @selected_period), class: "flex-1 px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-slate-500 transition-all", onchange: "this.form.requestSubmit()"

  -# Métricas globales
  .grid.grid-cols-1.md:grid-cols-2.lg:grid-cols-4.gap-6.mb-6

    -# Total a pagar (neto)
    .bg-white.border.border-slate-200.rounded-lg.shadow-sm.hover:shadow-md.transition-all.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-sm.font-medium.text-gray-600.mb-1 Total a Transferir
          %h3.text-3xl.font-bold.text-blue-600
            = currency_ar(@total_to_pay)

        .w-12.h-12.bg-blue-100.rounded-xl.flex.items-center.justify-center.text-2xl
          💸

      .text-sm.text-gray-500
        %span.font-medium.text-gray-700
          = @suppliers_with_payments.count
        %span= @suppliers_with_payments.count == 1 ? "proveedor" : "proveedores"

    -# Facturas (monto original)
    .bg-white.border.border-slate-200.rounded-lg.shadow-sm.hover:shadow-md.transition-all.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-sm.font-medium.text-gray-600.mb-1 Facturas Pendientes
          %h3.text-3xl.font-bold.text-gray-900
            = currency_ar(@total_invoices_amount)

        .w-12.h-12.bg-gray-100.rounded-xl.flex.items-center.justify-center.text-2xl
          📄

      .text-sm.text-gray-500
        %span.font-medium.text-gray-700
          = @total_invoices_count
        %span= @total_invoices_count == 1 ? "factura" : "facturas"

    -# Con Descuento
    - if @total_savings > 0
      .bg-white.border.border-emerald-200.rounded-lg.shadow-sm.hover:shadow-md.transition-all.p-6
        .flex.items-start.justify-between.mb-4
          .flex-1
            %p.text-sm.font-medium.text-gray-600.mb-1 Con Descuento
            %h3.text-3xl.font-bold.text-emerald-600
              = currency_ar(@total_invoices_with_discount)

          .w-12.h-12.bg-emerald-100.rounded-xl.flex.items-center.justify-center.text-2xl
            ⚡

        .text-sm.text-emerald-600
          %span.font-medium Ahorrás
          %span= currency_ar(@total_savings)
    - else
      .bg-white.border.border-slate-200.rounded-lg.shadow-sm.hover:shadow-md.transition-all.p-6
        .flex.items-start.justify-between.mb-4
          .flex-1
            %p.text-sm.font-medium.text-gray-600.mb-1 Con Descuento
            %h3.text-3xl.font-bold.text-gray-900
              = currency_ar(@total_invoices_with_discount)

          .w-12.h-12.bg-gray-100.rounded-xl.flex.items-center.justify-center.text-2xl
            ⚡

        .text-sm.text-gray-500
          %span Sin descuentos disponibles

    -# Créditos
    .bg-white.border.border-slate-200.rounded-lg.shadow-sm.hover:shadow-md.transition-all.p-6
      .flex.items-start.justify-between.mb-4
        .flex-1
          %p.text-sm.font-medium.text-gray-600.mb-1 Crédito Disponible
          %h3.text-3xl.font-bold{ class: @total_credits_amount > 0 ? "text-green-600" : "text-gray-900" }
            = "- #{currency_ar(@total_credits_amount)}"

        .w-12.h-12.rounded-xl.flex.items-center.justify-center.text-2xl{ class: @total_credits_amount > 0 ? "bg-green-100" : "bg-gray-100" }
          ✅

      .text-sm{ class: @total_credits_amount > 0 ? "text-green-600" : "text-gray-500" }
        %span.font-medium
          = @total_credits_count
        %span= @total_credits_count == 1 ? "nota de crédito" : "notas de crédito"

  -# Tabla unificada de pagos
  - if @suppliers_with_payments.any?
    .bg-white.border.border-slate-200.rounded-lg.overflow-hidden
      %table.min-w-full
        %thead.bg-slate-50
          %tr
            %th.px-4.py-3.text-left.text-xs.font-medium.text-slate-500.uppercase
              Proveedor
            %th.px-4.py-3.text-left.text-xs.font-medium.text-slate-500.uppercase
              N° Factura
            %th.px-4.py-3.text-center.text-xs.font-medium.text-slate-500.uppercase
              Vence Normal
            %th.px-4.py-3.text-center.text-xs.font-medium.text-slate-500.uppercase
              Vence Desc.
            %th.px-4.py-3.text-center.text-xs.font-medium.text-slate-500.uppercase
              Descuento
            %th.px-4.py-3.text-right.text-xs.font-medium.text-slate-500.uppercase
              Créditos
            %th.px-4.py-3.text-right.text-xs.font-medium.text-slate-500.uppercase
              Monto
            %th.px-4.py-3.text-right.text-xs.font-medium.text-slate-500.uppercase
              Con Desc.
            %th.px-4.py-3.text-center.text-xs.font-medium.text-slate-500.uppercase
              Acción

        %tbody.divide-y.divide-slate-100
          - @suppliers_with_payments.each do |data|
            - cn_json = data[:credit_notes].map { |cn| { id: cn.id, number: cn.credit_note_number, remaining_balance_ars: cn.remaining_balance_ars.to_f } }.to_json

            -# Fila principal del proveedor
            %tr.bg-slate-50.hover:bg-slate-100.transition-colors
              %td.px-4.py-4
                %p.font-semibold.text-slate-900= data[:supplier].name
                %p.text-xs.text-gray-500
                  = data[:invoices_count]
                  = data[:invoices_count] == 1 ? "factura" : "facturas"

              %td.px-4.py-4.text-gray-400 —
              %td.px-4.py-4.text-gray-400.text-center —
              %td.px-4.py-4.text-gray-400.text-center —
              %td.px-4.py-4.text-gray-400.text-center —

              %td.px-4.py-4.text-right
                - if data[:credits_amount] > 0
                  %p.font-medium.text-green-600
                    = "- #{currency_ar(data[:credits_amount])}"
                - else
                  %p.text-gray-400 —

              %td.px-4.py-4.text-right
                %p.font-medium.text-gray-900
                  = currency_ar(data[:invoices_amount])

              %td.px-4.py-4.text-right
                - if data[:invoices_amount] != data[:invoices_amount_with_discount]
                  %p.font-bold.text-emerald-600
                    = currency_ar(data[:invoices_amount_with_discount])
                - else
                  %p.font-medium.text-gray-900
                    = currency_ar(data[:invoices_amount_with_discount])

              %td.px-4.py-4.text-center
                %button{ type: "button",
                         class: "inline-flex items-center px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer",
                         data: { supplier_id: data[:supplier].id,
                                 supplier_name: data[:supplier].name,
                                 invoices_count: data[:invoices_count],
                                 invoices_total: data[:invoices_amount_with_discount].to_f,
                                 credit_notes: cn_json },
                         onclick: "openPaymentModal(this)" }
                  Pagar

            -# Filas de detalle de facturas
            - data[:invoices].each do |invoice|
              - has_discount = invoice.eligible_for_discount?
              %tr.hover:bg-slate-50.transition-colors
                %td.px-4.py-2.pl-8
                  %span.text-gray-400 └

                %td.px-4.py-2
                  %span.font-mono.text-sm{ class: has_discount ? "text-emerald-600 font-semibold" : "text-gray-700" }
                    = invoice.invoice_number

                %td.px-4.py-2.text-center
                  %span.text-sm.text-gray-600= invoice.due_date.strftime("%d/%m/%Y")

                %td.px-4.py-2.text-center
                  - if has_discount
                    %span.text-sm.text-emerald-600.font-medium= invoice.early_payment_due_date.strftime("%d/%m/%Y")
                  - else
                    %span.text-gray-400 —

                %td.px-4.py-2.text-center
                  - if has_discount
                    .inline-flex.items-center.gap-1.px-2.py-1.bg-emerald-100.text-emerald-700.rounded-md.text-xs.font-semibold
                      ⚡
                      = "#{invoice.early_payment_discount_percentage}%"
                  - else
                    %span.text-gray-400 —

                %td.px-4.py-2.text-right.text-gray-400 —

                %td.px-4.py-2.text-right
                  %span.text-sm.text-gray-600= currency_ar(invoice.total_amount)

                %td.px-4.py-2.text-right
                  - if has_discount
                    %span.text-sm.font-semibold.text-emerald-600= currency_ar(invoice.amount_with_discount_ars)
                  - else
                    %span.text-sm.text-gray-600= currency_ar(invoice.amount_with_discount_ars)

                %td.px-4.py-2

  -# Mensaje cuando no hay pagos
  - if @suppliers_with_payments.empty?
    .bg-white.border.border-slate-200.rounded-lg.p-16.text-center
      .inline-flex.w-20.h-20.rounded-full.bg-green-100.items-center.justify-center.text-4xl.mb-4
        ✓
      %h3.text-xl.font-bold.text-gray-900.mb-2 No hay pagos pendientes
      %p.text-gray-600
        No tienes facturas que venzan en el período seleccionado

-# Modal de pago
#paymentModal{ style: "display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0.5); z-index: 9999; align-items: center; justify-content: center;", onclick: "if(event.target === this) closePaymentModal()" }
  .bg-white.rounded-lg.p-6{ style: "max-width: 36rem; width: 100%; margin: 0 1rem; max-height: 90vh; overflow-y: auto;", onclick: "event.stopPropagation()" }
    .flex.items-center.justify-between.mb-4
      %h3#modalTitle.text-lg.font-semibold.text-gray-900 Pagar
      %button.text-gray-400.hover:text-gray-600.cursor-pointer{ type: "button", onclick: "closePaymentModal()" }
        %span.text-2xl ×

    %form#paymentForm{ method: "post", action: "#" }
      = hidden_field_tag :authenticity_token, form_authenticity_token

      -# Resumen del proveedor
      #supplierInfo.mb-4.p-3.bg-slate-50.rounded-lg
        %p#modalMessage.text-sm.text-slate-600

      -# Notas de crédito disponibles (se muestra solo si existen NCs con saldo)
      #creditNotesSection{ style: "display: none;" }
        .mb-4
          %h4.text-sm.font-semibold.text-gray-800.mb-3 Notas de Crédito Disponibles
          #creditNotesList
            -# Filled by JS

          -# Resumen de liquidación
          .mt-3.pt-3.border-t.border-gray-200.space-y-1
            .flex.justify-between.text-sm
              %span.text-gray-500 Total facturas:
              %span#modalInvoicesTotal.font-medium.text-gray-800
            .flex.justify-between.text-sm
              %span.text-gray-500 Créditos a aplicar:
              %span#modalCreditsApplied.font-medium.text-green-600
            .flex.justify-between.text-sm.font-semibold.pt-1.border-t.border-gray-100
              %span.text-gray-900 Neto a transferir:
              %span#modalNetTotal.text-blue-600

      -# Fecha de pago
      .mb-4
        %label.block.text-sm.font-medium.text-gray-700.mb-2
          Fecha de Pago
        = date_field_tag :payment_date, Date.current,
                        class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-gray-700 focus:border-transparent transition-all",
                        required: true

      .flex.items-center.gap-3
        %button.cursor-pointer.flex-1.px-4.py-2.border.border-slate-300.text-slate-700.font-semibold.rounded-lg.hover:bg-slate-50.transition-colors{ type: "button", onclick: "closePaymentModal()" }
          Cancelar

        %button.cursor-pointer.flex-1.px-4.py-2.bg-slate-700.hover:bg-slate-800.text-white.font-semibold.rounded-lg.transition-colors{ type: "submit" }
          Confirmar Pago

:javascript
  let currentSupplierData = null;

  function openPaymentModal(btn) {
    const modal     = document.getElementById('paymentModal');
    const form      = document.getElementById('paymentForm');
    const title     = document.getElementById('modalTitle');
    const message   = document.getElementById('modalMessage');
    const cnSection = document.getElementById('creditNotesSection');
    const cnList    = document.getElementById('creditNotesList');

    const supplierId    = btn.dataset.supplierId;
    const supplierName  = btn.dataset.supplierName;
    const invoicesCount = parseInt(btn.dataset.invoicesCount);
    const invoicesTotal = parseFloat(btn.dataset.invoicesTotal);
    const creditNotes   = JSON.parse(btn.dataset.creditNotes || '[]');

    currentSupplierData = { invoicesTotal };

    title.textContent   = `Pagar a ${supplierName}`;
    message.textContent = `${invoicesCount} ${invoicesCount === 1 ? 'factura' : 'facturas'} — Total: ${formatARS(invoicesTotal)}`;

    const period = #{@selected_period.to_json};
    form.action  = `/web/invoices/mark_supplier_paid?supplier_id=${supplierId}&period=${period}`;

    if (creditNotes.length > 0) {
      cnSection.style.display = 'block';
      cnList.innerHTML = creditNotes.map(cn => `
        <div class="mb-2 p-3 bg-green-50 border border-green-200 rounded-lg">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-green-800">${cn.number}</span>
            <span class="text-xs text-green-600">Saldo: ${formatARS(cn.remaining_balance_ars)}</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500 whitespace-nowrap">Aplicar ARS</span>
            <input
              type="number"
              class="flex-1 px-3 py-1.5 text-sm border border-green-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
              placeholder="0"
              min="0"
              max="${cn.remaining_balance_ars}"
              step="1"
              data-cn-id="${cn.id}"
              data-max="${cn.remaining_balance_ars}"
              oninput="recalculateNet()"
            />
          </div>
        </div>
      `).join('');

      document.getElementById('modalInvoicesTotal').textContent  = formatARS(invoicesTotal);
      document.getElementById('modalCreditsApplied').textContent = '— ' + formatARS(0);
      document.getElementById('modalNetTotal').textContent       = formatARS(invoicesTotal);
    } else {
      cnSection.style.display = 'none';
    }

    modal.style.display = 'flex';
  }

  function recalculateNet() {
    if (!currentSupplierData) return;

    const inputs = document.querySelectorAll('#creditNotesList input[data-cn-id]');
    let totalApplied = 0;

    inputs.forEach(input => {
      const max = parseFloat(input.dataset.max);
      let val   = parseFloat(input.value) || 0;
      if (val > max) { input.value = max; val = max; }
      if (val < 0)   { input.value = 0;   val = 0; }
      totalApplied += val;
    });

    const net = Math.max(0, currentSupplierData.invoicesTotal - totalApplied);
    document.getElementById('modalCreditsApplied').textContent = '— ' + formatARS(totalApplied);
    document.getElementById('modalNetTotal').textContent       = formatARS(net);
  }

  function closePaymentModal() {
    document.getElementById('paymentModal').style.display = 'none';
    currentSupplierData = null;
  }

  function formatARS(amount) {
    return new Intl.NumberFormat('es-AR', {
      style: 'currency', currency: 'ARS', minimumFractionDigits: 0, maximumFractionDigits: 0
    }).format(amount);
  }

  // Before submit: inject credit_applications hidden inputs
  document.addEventListener('DOMContentLoaded', function () {
    document.getElementById('paymentForm').addEventListener('submit', function () {
      this.querySelectorAll('input[name^="credit_applications"]').forEach(el => el.remove());

      let idx = 0;
      document.querySelectorAll('#creditNotesList input[data-cn-id]').forEach(input => {
        const val = parseFloat(input.value) || 0;
        if (val <= 0) return;

        const addHidden = (name, value) => {
          const el = document.createElement('input');
          el.type  = 'hidden';
          el.name  = name;
          el.value = value;
          this.appendChild(el);
        };

        addHidden(`credit_applications[${idx}][credit_note_id]`, input.dataset.cnId);
        addHidden(`credit_applications[${idx}][amount_ars]`, val);
        idx++;
      });
    });
  });
