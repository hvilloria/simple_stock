%aside.w-64.bg-white.border-r.border-slate-200.flex.flex-col.h-screen.fixed.left-0.top-0
  -# Logo
  .flex.items-center.justify-between.px-6.py-4.border-b.border-slate-200
    = link_to root_path, class: "flex items-center gap-3" do
      -# Logo con fondo rojo (único uso del color corporativo)
      .w-10.h-10.rounded-lg.bg-brand.flex.items-center.justify-center.shadow-sm
        %span.font-bold.text-lg.text-white GS
      
      %div
        %h1.font-bold.text-base.text-slate-900 Gente del Sol
        %p.text-xs.text-slate-500 Sistema de Gestión
  
  -# Navegación
  %nav.flex-1.px-3.py-4.space-y-1
    = link_to web_dashboard_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{controller_name == 'dashboard' ? 'text-slate-900 bg-slate-100' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors'}" do
      %span.text-base 📊
      %span Dashboard
    
    = link_to web_products_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{controller_name == 'products' ? 'text-slate-900 bg-slate-100' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors'}" do
      %span.text-base 📦
      %span Productos

    - if current_user&.caja? || current_user&.admin?
      - pending_notes_count = Order.immediate.pending.count
      - sale_notes_active = controller_path.start_with?('web/sale_notes')
      = link_to web_sale_notes_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{sale_notes_active ? 'text-slate-900 bg-slate-100' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors'}" do
        %span.text-base 🧾
        %span Notas de pedido
        - if pending_notes_count > 0
          %span.ml-auto.inline-flex.items-center.justify-center.w-5.h-5.rounded-full.bg-amber-100.text-amber-700.text-xs.font-bold= pending_notes_count

    - if current_user&.vendedor? || current_user&.caja? || current_user&.admin?
      - open_on_account_count = Order.open_on_account.length
      - payments_on_account_active = controller_path.start_with?('web/payments_on_account')
      = link_to web_payments_on_account_index_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{payments_on_account_active ? 'text-slate-900 bg-slate-100' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors'}" do
        %span.text-base 🗂️
        %span Pagos a cuenta
        - if open_on_account_count > 0
          %span.ml-auto.inline-flex.items-center.justify-center.w-5.h-5.rounded-full.bg-amber-100.text-amber-700.text-xs.font-bold= open_on_account_count

    -# Ventas (con submenu desplegable)
    - ventas_active = controller_path.start_with?('web/sales_ledger') || controller_name == 'orders'
    .nav-group{ data: { controller: "dropdown" } }
      %button.nav-item.nav-group-toggle{
        type: "button",
        data: { action: "click->dropdown#toggle" },
        class: (ventas_active ? 'bg-slate-100' : '')
      }
        .flex.items-center.justify-between.w-full
          .flex.items-center.gap-3
            .nav-icon
              %span.text-base 🛒
            %span.font-medium.text-slate-900 Ventas
          .nav-arrow{ data: { dropdown_target: "arrow" } }
            ▼

      .nav-submenu.pl-8.border-l-2.border-slate-200.ml-4{ data: { dropdown_target: "menu" } }
        = link_to web_orders_path, class: "nav-subitem #{controller_name == 'orders' ? 'active' : ''}" do
          %span.text-base 🧾
          %span Ventas del Sistema

        = link_to web_sales_ledger_imports_path, class: "nav-subitem #{controller_name == 'imports' ? 'active' : ''}" do
          %span.text-base 📋
          %span Ventas Importadas

        = link_to web_sales_ledger_reports_path, class: "nav-subitem #{controller_name == 'reports' ? 'active' : ''}" do
          %span.text-base 📊
          %span Reportes
    
    -# Clientes (con submenu)
    - clientes_active = controller_name == 'customers' || controller_path.start_with?('web/customers/')
    - debtors_count = Customer.with_outstanding_balance.count
    .nav-group{ data: { controller: "dropdown" } }
      %button.nav-item.nav-group-toggle{
        type: "button",
        data: { action: "click->dropdown#toggle" },
        class: (clientes_active ? 'bg-slate-100' : '')
      }
        .flex.items-center.justify-between.w-full
          .flex.items-center.gap-3
            .nav-icon
              %span.text-base 👥
            %span.font-medium.text-slate-900 Clientes
          .nav-arrow{ data: { dropdown_target: "arrow" } }
            ▼

      .nav-submenu.pl-8.border-l-2.border-slate-200.ml-4{ data: { dropdown_target: "menu" } }
        = link_to web_customers_path, class: "nav-subitem #{(clientes_active && action_name != 'debtors') ? 'active' : ''}" do
          %span.text-base 👤
          %span Todos los Clientes

        = link_to debtors_web_customers_path, class: "nav-subitem #{(controller_name == 'customers' && action_name == 'debtors') ? 'active' : ''}" do
          .flex.items-center.justify-between.w-full
            .flex.items-center.gap-2
              %span.text-base 💳
              %span Cuentas por Cobrar
            - if debtors_count > 0
              %span.inline-flex.items-center.justify-center.w-5.h-5.rounded-full.bg-amber-100.text-amber-700.text-xs.font-bold
                = debtors_count
    
    -# Facturación (con submenu desplegable)
    .nav-group{ data: { controller: "dropdown" } }
      %button.nav-item.nav-group-toggle{ 
        type: "button",
        data: { action: "click->dropdown#toggle" },
        class: (['invoices', 'credit_notes'].include?(controller_name) ? 'bg-slate-100' : '')
      }
        .flex.items-center.justify-between.w-full
          .flex.items-center.gap-3
            .nav-icon
              %span.text-base 📥
            %span.font-medium.text-slate-900 Facturación
          .nav-arrow{ data: { dropdown_target: "arrow" } }
            ▼
      
      .nav-submenu.pl-8.border-l-2.border-slate-200.ml-4{ data: { dropdown_target: "menu" } }
        = link_to web_invoices_path, class: "nav-subitem #{(controller_name == 'invoices' && action_name != 'pending') ? 'active' : ''}" do
          %span.text-base 📄
          %span Facturas
        
        = link_to web_credit_notes_path, class: "nav-subitem #{controller_name == 'credit_notes' ? 'active' : ''}" do
          %span.text-base ✓
          %span Notas de Crédito
        
        = link_to pending_web_invoices_path, class: "nav-subitem #{(controller_name == 'invoices' && action_name == 'pending') ? 'active' : ''}" do
          %span.text-base 💸
          %span Pagos Pendientes
    
    - if policy(Supplier).index?
      = link_to web_suppliers_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium #{controller_name == 'suppliers' ? 'text-slate-900 bg-slate-100' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors'}" do
        %span.text-base 🏭
        %span Proveedores
  
  -# Usuario
  .px-3.py-4.border-t.border-slate-200
    .flex.items-center.gap-3.px-3.py-2
      .w-8.h-8.rounded-full.bg-slate-200.flex.items-center.justify-center.text-slate-700.text-sm.font-semibold
        A
      .flex-1.min-w-0
        %p.text-sm.font-medium.text-slate-900.truncate Alfredo
        %p.text-xs.text-slate-500 Admin
